def get_feedback(score, total):
percentage = (score / total) * 100 if percentage == 100:
return "  Perfect Score! Outstanding!", "perfect" elif percentage >= 80:
return "  Excellent! Great job!", "excellent" elif percentage >= 60:
return "  Good work! Keep it up!", "good" elif percentage >= 40:
return "  Fair attempt. More practice needed.", "fair" else:
return "  Don't give up! Try again!", "poor"


