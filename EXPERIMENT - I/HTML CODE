<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Personal Portfolio</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Header Section -->
    <header>
        <h1> Akash </h1>
        <p>Web Developer | Learner | Tech Enthusiast</p>
    </header>

    <!-- Navigation -->
    <nav>
        <a href="#about">About</a>
        <a href="#skills">Skills</a>
        <a href="#projects">Projects</a>
        <a href="#contact">Contact</a>
    </nav>

    <!-- Welcome Message -->
    <section class="welcome">
        <h2>Welcome to My Portfolio 👋</h2>
        <button onclick="showAlert()">Click Me</button>
    </section>

    <!-- About Me -->
    <section id="about">
        <h2>About Me</h2>
        <p>
            I am a passionate student learning web development. 
            I enjoy creating simple, clean, and user-friendly websites.
        </p>
    </section>

    <!-- Skills -->
    <section id="skills">
        <h2>Skills</h2>
        <ul>
            <li>HTML</li>
            <li>CSS</li>
            <li>JavaScript</li>
        </ul>
    </section>

    <!-- Projects -->
    <section id="projects">
        <h2>Projects</h2>

        <div class="project-card">
            <h3>Portfolio Website</h3>
            <p>A personal portfolio built using HTML, CSS, and JavaScript.</p>
        </div>

        <div class="project-card">
            <h3>Calculator App</h3>
            <p>A simple calculator performing basic arithmetic operations.</p>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact">
        <h2>Contact Me</h2>

        <form onsubmit="return submitForm()">
            <input type="text" id="name" placeholder="Your Name" required>
            <input type="email" id="email" placeholder="Your Email" required>
            <textarea id="message" placeholder="Your Message" required></textarea>
            <button type="submit">Submit</button>
        </form>

        <p id="confirmation"></p>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2026 Akash. All rights reserved.</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
